# =============================================
# Claude Proxy - Environment Variables
# Copy to .env and fill in the values
# =============================================

# --- REQUIRED ---

# Secret key for JWT session tokens (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret-please

# Admin credentials (used on first run to create the admin account)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# --- OPTIONAL ---

# Port for the web admin dashboard (default: 3000)
WEB_PORT=3000

# Port for the Anthropic proxy (default: 8080)
# Use in Claude CLI: export ANTHROPIC_BASE_URL=http://localhost:8080
PROXY_PORT=8080

# Path to SQLite database (inside Docker volume)
DB_PATH=/data/claude-proxy.db

# Anthropic API upstream URL
ANTHROPIC_URL=https://api.anthropic.com

# OAuth token refresh endpoint
OAUTH_REFRESH_URL=https://console.anthropic.com/v1/auth/oauth2/token

# Encryption key for storing OAuth tokens in DB
# Defaults to JWT_SECRET if not set
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# JWT session expiry in hours (default: 24)
JWT_EXPIRY_HOURS=24

# Auto-reset exhausted accounts every N minutes (0 = disabled)
# Useful when Claude accounts recover after a cooldown period
# Example: 60 = reset all exhausted accounts every hour
POOL_RESET_INTERVAL_MINUTES=60

# =============================================
# Usage with Claude CLI:
#
#   export ANTHROPIC_BASE_URL=http://localhost:8080
#   export ANTHROPIC_AUTH_TOKEN=sk-proxy-<your-token>
#   export NO_PROXY=localhost,127.0.0.1
#   claude "hello"
# =============================================
